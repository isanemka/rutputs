# AWS SES Configuration

AWS_ACCESS_KEY_ID=//INSERT YOUR AWS ACCESS KEY HERE
AWS_SECRET_ACCESS_KEY=//INSERT YOUR AWS SECRET KEY HERE
AWS_REGION=//INSERT YOUR AWS REGION HERE (e.g. eu-north-1)

# Email addresses

SES_FROM_EMAIL=your-verified-sender@example.com
SES_TO_EMAIL=recipient@example.com

# PPCRM integration

PPCRM_LEADS_URL=https://your-ppcrm-domain.example/api/leads
PPCRM_LEADS_SECRET=//INSERT YOUR PPCRM LEADS SECRET HERE
PPCRM_AVAILABILITY_URL=https://your-ppcrm-domain.example/api/availability
PPCRM_AVAILABILITY_SECRET=//INSERT YOUR PPCRM AVAILABILITY SECRET HERE

# Discount codes (optional)

# Comma-separated list of CODE:PERCENT pairs, e.g. GRANNE10:10,VIP20:20

DISCOUNT_CODES=

# Analytics & ads (frontend, exposed at build-time via Vite)

# Google Analytics 4 (default fallback in code is G-5SEKFW68XH)

VITE_GA_MEASUREMENT_ID=

# Optional: Google Tag Manager (takes precedence over GA4 + Ads direct loads)

VITE_GTM_ID=

# Google Ads conversion tracking, e.g. AW-1234567890

VITE_GOOGLE_ADS_ID=

# Backwards-compatible fallback used as lead label if VITE_GOOGLE_ADS_LEAD_LABEL is unset

VITE_GOOGLE_ADS_CONVERSION_LABEL=

# Lead conversion label, e.g. AbC-D_efGhIj12kLmN (form/lead-submit)

VITE_GOOGLE_ADS_LEAD_LABEL=

# Phone-call conversion label (tel: clicks)

VITE_GOOGLE_ADS_PHONE_LABEL=

# Optional separate label for form submits (otherwise unused)

VITE_GOOGLE_ADS_FORM_LABEL=

# Meta (Facebook) Pixel ID, e.g. 1234567890123456

VITE_META_PIXEL_ID=

# Microsoft Clarity project ID (gratis heatmaps + session replay)

VITE_CLARITY_ID=

# Scripts

# Google Search Console – weekly report (scripts/gsc-report.mjs)

# Uses Application Default Credentials (ADC), no key needed.

# Override site URL if your GSC property differs from the default.

GSC_SITE_URL=sc-domain:rutputs.nu

# pp-cc guide webhook (api/guide-webhook.js)

# HMAC secret that must match the Rutputs customer's webhook config in pp-cc.

PPCC_WEBHOOK_SECRET=

# GitHub PAT with `contents: write` on this repo. Used to commit new/updated

# guides directly to the default branch when pp-cc publishes.

GITHUB_TOKEN=

# Optional: override the target repo / branch / site URL.

# GITHUB_REPO=isanemka/rutputs

# GITHUB_BRANCH=main

# SITE_URL=https://rutputs.nu
