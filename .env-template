# AWS SES Configuration

AWS_ACCESS_KEY_ID=//INSERT YOUR AWS ACCESS KEY HERE
AWS_SECRET_ACCESS_KEY=//INSERT YOUR AWS SECRET KEY HERE
AWS_REGION=//INSERT YOUR AWS REGION HERE (e.g. eu-north-1)

# Email addresses

SES_FROM_EMAIL=your-verified-sender@example.com
SES_TO_EMAIL=recipient@example.com

# PPCRM integration

PPCRM_LEADS_URL=https://your-ppcrm-domain.example/api/leads
PPCRM_LEADS_SECRET=//INSERT YOUR PPCRM LEADS SECRET HERE
PPCRM_AVAILABILITY_URL=https://your-ppcrm-domain.example/api/availability
PPCRM_AVAILABILITY_SECRET=//INSERT YOUR PPCRM AVAILABILITY SECRET HERE
